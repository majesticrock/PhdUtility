@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include(
    "${CMAKE_CURRENT_LIST_DIR}/mrock-targets.cmake"
)

set(mrock_AVAILABLE_COMPONENTS
    utility
    symbolic_operators
    iEoM
)
set(mrock_LIBRARIES mrock::mrock)

#
# If no components were requested, enable all components
#
if(NOT mrock_FIND_COMPONENTS)
    set(mrock_FIND_COMPONENTS
        ${mrock_AVAILABLE_COMPONENTS}
    )
endif()

foreach(component IN LISTS mrock_FIND_COMPONENTS)
    if (NOT component IN_LIST mrock_AVAILABLE_COMPONENTS)
        set(mrock_FOUND FALSE)
        set(mrock_NOT_FOUND_MESSAGE "Unknown component: ${component}")
    endif()

    include("${CMAKE_CURRENT_LIST_DIR}/../mrock_${component}/mrock_${component}-config.cmake")

    set(mrock_LIBRARIES
        ${mrock_LIBRARIES}
        mrock::${component}
    )
endforeach()

set(mrock_VERSION "@PROJECT_VERSION@")

check_required_components(mrock)