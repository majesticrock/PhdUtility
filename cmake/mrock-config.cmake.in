@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include(
    "${CMAKE_CURRENT_LIST_DIR}/mrock-targets.cmake"
)

set(mrock_AVAILABLE_COMPONENTS
    utility
    symbolic_operators
    iEoM
)

if(mrock_FIND_COMPONENTS)
    foreach(component IN LISTS mrock_FIND_COMPONENTS)
        if(component STREQUAL "utility")

            find_dependency(mrock_utility)

        elseif(component STREQUAL "symbolic_operators")

            find_dependency(mrock_symbolic_operators)

        elseif(component STREQUAL "iEoM")

            find_dependency(mrock_iEoM)

        else()

            message(
                FATAL_ERROR
                "Unknown mrock component: ${component}"
            )

        endif()
    endforeach()
endif()

set(mrock_VERSION "@PROJECT_VERSION@")

check_required_components(mrock)